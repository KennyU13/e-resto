            <rightOperand xmi:type="expression:Expression" xmi:id="_f1pXJE1SEfGoaN6XFzkA-A" name="Reservation" content="import com.company.model.Reservation&#xA;import com.company.model.Cliente&#xA;import java.time.LocalDate&#xA;def categorieDemandee = reservationInput?.categorieChambre&#xA;def nuits = Math.max(((reservationInput?.nbNuits ?: 1) as Integer), 1)&#xA;def chambres = chambre ? chambre.findAll { it != null } : []&#xA;def articles = article ? article.findAll { it != null } : []&#xA;def matchesCategory = { ch ->&#xA;    def cat = ch?.categorie&#xA;    if (cat == null) {&#xA;        return false&#xA;    }&#xA;    if (cat instanceof Collection) {&#xA;        return cat.any { it?.nom == categorieDemandee }&#xA;    }&#xA;    return cat.nom == categorieDemandee&#xA;}&#xA;def tracked = [&quot;gel douche&quot;, &quot;papier hygienique&quot;, &quot;pantoufle&quot;, &quot;brosse a dent&quot;] as Set&#xA;def stockInsuffisant = articles.find { current ->&#xA;    tracked.contains((current?.nom ?: &quot;&quot;).toString().toLowerCase()) &amp;&amp; ((current?.quantiteStock ?: 0) as Integer) &lt; nuits&#xA;}&#xA;if (stockInsuffisant != null) {&#xA;    throw new IllegalStateException(&quot;Stock insuffisant pour l'article : &quot; + stockInsuffisant.nom)&#xA;}&#xA;def chambreChoisie = chambres.find { ch -> matchesCategory(ch) &amp;&amp; ch?.statut == &quot;propre&quot; }&#xA;if (chambreChoisie == null) {&#xA;    throw new IllegalStateException(&quot;Aucune chambre propre disponible pour la categorie : &quot; + categorieDemandee)&#xA;}&#xA;def r = new Reservation()&#xA;def c = new Cliente()&#xA;c.nomClient = reservationInput?.cliente?.nomClient&#xA;c.prenomClient = reservationInput?.cliente?.prenomClient&#xA;c.telephone = reservationInput?.cliente?.telephone&#xA;c.email = reservationInput?.cliente?.email&#xA;c.pieceIdentite = reservationInput?.cliente?.pieceIdentite&#xA;r.cliente = c&#xA;r.nbNuits = nuits&#xA;r.dateReservation = LocalDate.now()&#xA;r.chambre = chambreChoisie&#xA;r.statut = &quot;ACTIVE&quot;&#xA;return r" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.company.model.Reservation">
