            </leftOperand>
            <rightOperand xmi:type="expression:Expression" xmi:id="_f1pXDk1SEfGoaN6XFzkA-A" name="InitialiserArticles" content="import com.company.model.Article&#xA;&#xA;def noms = [&quot;gel douche&quot;, &quot;papier hygienique&quot;, &quot;pantoufle&quot;, &quot;brosse a dent&quot;]&#xA;def existants = []&#xA;try {&#xA;    existants = articleDAO.find(0, 1000).findAll { it != null }&#xA;} catch (Throwable ignored) {&#xA;    existants = article ? article.findAll { it != null } : []&#xA;}&#xA;&#xA;def parNom = [:]&#xA;existants.each { item ->&#xA;    def cle = (item?.nom ?: &quot;&quot;).toString().toLowerCase()&#xA;    if (cle &amp;&amp; !parNom.containsKey(cle)) {&#xA;        parNom[cle] = item&#xA;    }&#xA;}&#xA;&#xA;noms.each { nomArticle ->&#xA;    def cle = nomArticle.toLowerCase()&#xA;    if (!parNom.containsKey(cle)) {&#xA;        def item = new Article()&#xA;        item.nom = nomArticle&#xA;        item.quantiteStock = 100&#xA;        parNom[cle] = item&#xA;    }&#xA;}&#xA;&#xA;return noms.collect { parNom[it.toLowerCase()] }" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="java.util.List">
