            </leftOperand>
            <rightOperand xmi:type="expression:Expression" xmi:id="_f1pXCE1SEfGoaN6XFzkA-A" name="InitialiserCategories" content="import com.company.model.CategorieChambre&#xA;&#xA;def specs = [[nom: &quot;Standard&quot;, prixNuit: 15000d], [nom: &quot;Suite Senior&quot;, prixNuit: 30000d], [nom: &quot;Suite Prestige&quot;, prixNuit: 45000d]]&#xA;def existantes = []&#xA;try {&#xA;    existantes = categorieChambreDAO.find(0, 1000).findAll { it != null }&#xA;} catch (Throwable ignored) {&#xA;    existantes = categorie ? categorie.findAll { it != null } : []&#xA;}&#xA;&#xA;def parNom = [:]&#xA;existantes.each { item ->&#xA;    if (item?.nom &amp;&amp; !parNom.containsKey(item.nom)) {&#xA;        parNom[item.nom] = item&#xA;    }&#xA;}&#xA;&#xA;specs.each { spec ->&#xA;    if (!parNom.containsKey(spec.nom)) {&#xA;        def item = new CategorieChambre()&#xA;        item.nom = spec.nom&#xA;        item.prixNuit = spec.prixNuit&#xA;        parNom[spec.nom] = item&#xA;    }&#xA;}&#xA;&#xA;return specs.collect { parNom[it.nom] }" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="java.util.List">
