              <referencedElements xmi:type="process:BusinessObjectData" xmi:id="_f1pXE01SEfGoaN6XFzkA-A" name="chambre" multiple="true" dataType="_f1pYak1SEfGoaN6XFzkA-A" className="com.company.model.Chambre"/>
            </leftOperand>
            <rightOperand xmi:type="expression:Expression" xmi:id="_f1pXFE1SEfGoaN6XFzkA-A" name="InitialiserChambres" content="import com.company.model.Chambre&#xA;&#xA;def specs = [[nom: &quot;Standard&quot;, debut: 101, fin: 106], [nom: &quot;Suite Senior&quot;, debut: 201, fin: 206], [nom: &quot;Suite Prestige&quot;, debut: 301, fin: 306]]&#xA;def categories = categorie ? categorie.findAll { it != null } : []&#xA;def rooms = []&#xA;try {&#xA;    rooms = chambreDAO.find(0, 5000).findAll { it != null }&#xA;} catch (Throwable ignored) {&#xA;    rooms = chambre ? chambre.findAll { it != null } : []&#xA;}&#xA;&#xA;def rangStatut = { statut ->&#xA;    def value = (statut ?: &quot;&quot;).toString().toLowerCase()&#xA;    if (value == &quot;sale&quot;) { return 3 }&#xA;    if (value == &quot;occupee&quot;) { return 2 }&#xA;    if (value == &quot;propre&quot;) { return 1 }&#xA;    return 0&#xA;}&#xA;&#xA;def assignCategory = { room, cat ->&#xA;    if (cat == null) { return }&#xA;    try {&#xA;        room.categorie = cat&#xA;    } catch (Throwable ignored) {&#xA;        room.categorie = [cat]&#xA;    }&#xA;}&#xA;&#xA;def parNumero = [:]&#xA;rooms.each { room ->&#xA;    if (room?.numero != null) {&#xA;        def current = parNumero[room.numero]&#xA;        if (current == null || rangStatut(room.statut) > rangStatut(current.statut)) {&#xA;            parNumero[room.numero] = room&#xA;        }&#xA;    }&#xA;}&#xA;&#xA;specs.each { spec ->&#xA;    def cat = categories.find { it.nom == spec.nom }&#xA;    (spec.debut..spec.fin).each { numero ->&#xA;        def room = parNumero[numero]&#xA;        if (room == null) {&#xA;            room = new Chambre()&#xA;            room.numero = numero&#xA;            room.statut = &quot;propre&quot;&#xA;            assignCategory(room, cat)&#xA;            parNumero[numero] = room&#xA;        } else {&#xA;            if (!room.statut) { room.statut = &quot;propre&quot; }&#xA;            if (!room.categorie) { assignCategory(room, cat) }&#xA;        }&#xA;    }&#xA;}&#xA;&#xA;return specs.collectMany { spec -> (spec.debut..spec.fin).collect { numero -> parNumero[numero] } }" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="java.util.List">
