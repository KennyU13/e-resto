              <referencedElements xmi:type="process:BusinessObjectData" xmi:id="_cngQ2Tc9EfGe6_ZwN8gWKQ" name="chambre" multiple="true" dataType="_cngSHTc9EfGe6_ZwN8gWKQ" className="com.company.model.Chambre"/>
            </leftOperand>
            <rightOperand xmi:type="expression:Expression" xmi:id="_cngQ2jc9EfGe6_ZwN8gWKQ" name="InitialiserChambres" content="import com.company.model.Chambre&#xD;&#xA;&#xD;&#xA;def categories = categorie ? categorie.findAll { it != null } : []&#xD;&#xA;def rooms = chambre ? chambre.findAll { it != null } : []&#xD;&#xA;&#xD;&#xA;def assignCategory = { room, cat ->&#xD;&#xA;    if (cat == null) {&#xD;&#xA;        return&#xD;&#xA;    }&#xD;&#xA;    try {&#xD;&#xA;        room.categorie = cat&#xD;&#xA;    } catch (Throwable ignored) {&#xD;&#xA;        room.categorie = [cat]&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;[[nom: &quot;Standard&quot;, debut: 101, fin: 106], [nom: &quot;Suite Senior&quot;, debut: 201, fin: 206], [nom: &quot;Suite Prestige&quot;, debut: 301, fin: 306]].each { spec ->&#xD;&#xA;    def cat = categories.find { it.nom == spec.nom }&#xD;&#xA;    (spec.debut..spec.fin).each { numero ->&#xD;&#xA;        def existing = rooms.find { it.numero == numero }&#xD;&#xA;        if (existing == null) {&#xD;&#xA;            def room = new Chambre()&#xD;&#xA;            room.numero = numero&#xD;&#xA;            room.statut = &quot;propre&quot;&#xD;&#xA;            assignCategory(room, cat)&#xD;&#xA;            rooms &lt;&lt; room&#xD;&#xA;        } else {&#xD;&#xA;            if (!existing.statut) {&#xD;&#xA;                existing.statut = &quot;propre&quot;&#xD;&#xA;            }&#xD;&#xA;            if (!existing.categorie) {&#xD;&#xA;                assignCategory(existing, cat)&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;return rooms" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="java.util.List">
              <referencedElements xmi:type="process:BusinessObjectData" xmi:id="_cngQ2zc9EfGe6_ZwN8gWKQ" name="chambre" multiple="true" dataType="_cngSHTc9EfGe6_ZwN8gWKQ" className="com.company.model.Chambre"/>
