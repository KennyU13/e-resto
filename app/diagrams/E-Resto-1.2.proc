              <referencedElements xmi:type="process:BusinessObjectData" xmi:id="_cngQ0zc9EfGe6_ZwN8gWKQ" name="article" multiple="true" dataType="_cngSHTc9EfGe6_ZwN8gWKQ" className="com.company.model.Article"/>
            </leftOperand>
            <rightOperand xmi:type="expression:Expression" xmi:id="_cngQ1Dc9EfGe6_ZwN8gWKQ" name="InitialiserArticles" content="import com.company.model.Article&#xD;&#xA;&#xD;&#xA;def result = article ? article.findAll { it != null } : []&#xD;&#xA;[&quot;gel douche&quot;, &quot;papier hygienique&quot;, &quot;pantoufle&quot;, &quot;brosse a dent&quot;].each { nomArticle ->&#xD;&#xA;    if (!result.any { (it.nom ?: &quot;&quot;).equalsIgnoreCase(nomArticle) }) {&#xD;&#xA;        def item = new Article()&#xD;&#xA;        item.nom = nomArticle&#xD;&#xA;        item.quantiteStock = 100&#xD;&#xA;        result &lt;&lt; item&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;return result" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="java.util.List">
