            </leftOperand>
            <rightOperand xmi:type="expression:Expression" xmi:id="_cngQ4Tc9EfGe6_ZwN8gWKQ" name="Reservation" content="import com.company.model.Reservation&#xD;&#xA;import com.company.model.Cliente&#xD;&#xA;import java.time.LocalDate&#xD;&#xA;&#xD;&#xA;def categorieDemandee = reservationInput?.categorieChambre&#xD;&#xA;def chambres = chambre ? chambre.findAll { it != null } : []&#xD;&#xA;&#xD;&#xA;def matchesCategory = { ch ->&#xD;&#xA;    def cat = ch?.categorie&#xD;&#xA;    if (cat == null) {&#xD;&#xA;        return false&#xD;&#xA;    }&#xD;&#xA;    if (cat instanceof Collection) {&#xD;&#xA;        return cat.any { it?.nom == categorieDemandee }&#xD;&#xA;    }&#xD;&#xA;    return cat.nom == categorieDemandee&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;def chambreLibre = chambres.find { ch -> ch?.statut == &quot;propre&quot; &amp;&amp; matchesCategory(ch) }&#xD;&#xA;if (chambreLibre == null) {&#xD;&#xA;    throw new IllegalStateException(&quot;Aucune chambre propre disponible pour la categorie : &quot; + categorieDemandee)&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;def r = new Reservation()&#xD;&#xA;def c = new Cliente()&#xD;&#xA;c.nomClient = reservationInput?.cliente?.nomClient&#xD;&#xA;c.prenomClient = reservationInput?.cliente?.prenomClient&#xD;&#xA;c.telephone = reservationInput?.cliente?.telephone&#xD;&#xA;c.email = reservationInput?.cliente?.email&#xD;&#xA;c.pieceIdentite = reservationInput?.cliente?.pieceIdentite&#xD;&#xA;&#xD;&#xA;r.cliente = c&#xD;&#xA;r.nbNuits = reservationInput?.nbNuits&#xD;&#xA;r.dateReservation = LocalDate.now()&#xD;&#xA;r.statut = &quot;ACTIVE&quot;&#xD;&#xA;r.chambre = chambreLibre&#xD;&#xA;chambreLibre.statut = &quot;occupee&quot;&#xD;&#xA;&#xD;&#xA;return r" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="com.company.model.Reservation">
