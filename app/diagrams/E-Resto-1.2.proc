              <referencedElements xmi:type="process:BusinessObjectData" xmi:id="_cngQzTc9EfGe6_ZwN8gWKQ" name="categorie" multiple="true" dataType="_cngSHTc9EfGe6_ZwN8gWKQ" className="com.company.model.CategorieChambre"/>
            </leftOperand>
            <rightOperand xmi:type="expression:Expression" xmi:id="_cngQzjc9EfGe6_ZwN8gWKQ" name="InitialiserCategories" content="import com.company.model.CategorieChambre&#xD;&#xA;&#xD;&#xA;def result = categorie ? categorie.findAll { it != null } : []&#xD;&#xA;[[nom: &quot;Standard&quot;, prixNuit: 15000d], [nom: &quot;Suite Senior&quot;, prixNuit: 30000d], [nom: &quot;Suite Prestige&quot;, prixNuit: 45000d]].each { spec ->&#xD;&#xA;    if (!result.any { it.nom == spec.nom }) {&#xD;&#xA;        def item = new CategorieChambre()&#xD;&#xA;        item.nom = spec.nom&#xD;&#xA;        item.prixNuit = spec.prixNuit&#xD;&#xA;        result &lt;&lt; item&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;return result" interpreter="GROOVY" type="TYPE_READ_ONLY_SCRIPT" returnType="java.util.List">
              <referencedElements xmi:type="process:BusinessObjectData" xmi:id="_cngQzzc9EfGe6_ZwN8gWKQ" name="categorie" multiple="true" dataType="_cngSHTc9EfGe6_ZwN8gWKQ" className="com.company.model.CategorieChambre"/>
