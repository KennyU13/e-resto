  "variables": {
    "task": {
      "type": "url",
      "value": [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed": false
    },
    "articles": {
      "type": "url",
      "value": [
        "../API/bdm/businessData/com.company.model.Article?q=find&p=0&c=99"
      ],
      "exposed": false
    },
    "stock_metrics_html": {
      "type": "expression",
      "exposed": false,
      "value": [
        "const list=Array.isArray($data.articles)?$data.articles:[];",
        "const tracked=list.length;",
        "const units=list.reduce((sum,item)=>sum+Number(item.quantiteStock||0),0);",
        "const alerts=list.filter(item=>Number(item.quantiteStock||0)<=10).length;",
        "return \"<div class='row'><div class='col-sm-4'><div class='panel panel-default'><div class='panel-body'><strong>Articles suivis</strong><h3>\"+tracked+\"</h3></div></div></div><div class='col-sm-4'><div class='panel panel-default'><div class='panel-body'><strong>Unites en stock</strong><h3>\"+units+\"</h3></div></div></div><div class='col-sm-4'><div class='panel panel-default'><div class='panel-body'><strong>Alertes stock faible</strong><h3>\"+alerts+\"</h3></div></div></div></div>\";"
      ]
    },
    "stock_table_html": {
      "type": "expression",
      "exposed": false,
      "value": [
        "const list=Array.isArray($data.articles)?$data.articles.slice():[];",
        "if(!list.length){return \"<div class='alert alert-info'>Aucun article trouve.</div>\";}",
        "list.sort((a,b)=>String(a.nom||'').localeCompare(String(b.nom||'')));",
        "const rows=list.map(item=>{const q=Number(item.quantiteStock||0);const etat=q<=10?\"Stock faible\":\"OK\";return \"<tr><td>\"+(item.nom||'-')+\"</td><td>\"+q+\"</td><td>\"+etat+\"</td></tr>\";}).join('');",
        "return \"<div class='panel panel-default'><div class='panel-body'><table class='table table-bordered table-striped'><thead><tr><th>Article</th><th>Stock</th><th>Etat</th></tr></thead><tbody>\"+rows+\"</tbody></table></div></div>\";"
      ]
    },
    "submit_errors_list": {
      "type": "expression",
      "value": [
        "if($data.formOutput&&$data.formOutput._submitError&&$data.formOutput._submitError.explanations){",
        "const li=$data.formOutput._submitError.explanations.filter(c=>c!==null).map(c=>\"<li>\"+c+\"</li>\").join('');",
        "if(li){return \"<ul>\"+li+\"</ul>\";}}"
      ],
      "exposed": false
    },
    "formOutput": {
      "type": "expression",
      "value": [
        "return {};"
      ],
      "exposed": false
    },
    "taskId": {
      "type": "urlparameter",
      "value": [
        "id"
      ],
      "exposed": false
    }
