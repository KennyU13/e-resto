    "factures": {
      "type": "url",
      "value": [
        "../API/bdm/businessData/com.company.model.Facture?q=find&p=0&c=999"
      ],
      "exposed": false
    },
    "chambres": {
      "type": "url",
      "value": [
        "../API/bdm/businessData/com.company.model.Chambre?q=find&p=0&c=200"
      ],
      "exposed": false
    },
    "articles": {
      "type": "url",
      "value": [
        "../API/bdm/businessData/com.company.model.Article?q=find&p=0&c=99"
      ],
      "exposed": false
    },
    "dashboard_metrics_html": {
      "type": "expression",
      "exposed": false,
      "value": [
        "const factures=Array.isArray($data.factures)?$data.factures:[];",
        "const chambres=Array.isArray($data.chambres)?$data.chambres:[];",
        "const articles=Array.isArray($data.articles)?$data.articles:[];",
        "const norm=value=>String(value||'').toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g,'');",
        "const totalMontant=factures.reduce((sum,item)=>sum+Number(item.montant||0),0);",
        "const payees=factures.filter(item=>norm(item.statutPaiement)==='paye').length;",
        "const occupees=chambres.filter(item=>norm(item.statut).includes('occupee')).length;",
        "const propres=chambres.filter(item=>norm(item.statut)==='propre').length;",
        "const sales=chambres.filter(item=>norm(item.statut)==='sale').length;",
        "const alertes=articles.filter(item=>Number(item.quantiteStock||0)<=10).length;",
        "return \"<div class='row'><div class='col-sm-6 col-md-4'><div class='panel panel-default'><div class='panel-body'><strong>Nombre de factures</strong><h3>\"+factures.length+\"</h3></div></div></div><div class='col-sm-6 col-md-4'><div class='panel panel-default'><div class='panel-body'><strong>Factures payees</strong><h3>\"+payees+\"</h3></div></div></div><div class='col-sm-6 col-md-4'><div class='panel panel-default'><div class='panel-body'><strong>Montant total</strong><h3>\"+totalMontant+\" Ar</h3></div></div></div><div class='col-sm-6 col-md-4'><div class='panel panel-default'><div class='panel-body'><strong>Chambres occupees</strong><h3>\"+occupees+\"</h3></div></div></div><div class='col-sm-6 col-md-4'><div class='panel panel-default'><div class='panel-body'><strong>Chambres libres et propres</strong><h3>\"+propres+\"</h3></div></div></div><div class='col-sm-6 col-md-4'><div class='panel panel-default'><div class='panel-body'><strong>Chambres a nettoyer</strong><h3>\"+sales+\"</h3></div></div></div><div class='col-sm-6 col-md-4'><div class='panel panel-default'><div class='panel-body'><strong>Articles en alerte</strong><h3>\"+alertes+\"</h3></div></div></div></div>\";"
      ]
    },
    "dashboard_factures_html": {
      "type": "expression",
      "exposed": false,
      "value": [
        "const factures=Array.isArray($data.factures)?$data.factures.slice():[];",
        "if(!factures.length){return \"<div class='panel panel-default'><div class='panel-heading'><strong>Factures recentes</strong></div><div class='panel-body'>Aucune facture disponible.</div></div>\";}",
        "factures.sort((a,b)=>new Date(b.dateFacture||0)-new Date(a.dateFacture||0));",
        "const rows=factures.slice(0,8).map(item=>{const d=item.dateFacture?new Date(item.dateFacture).toLocaleDateString('fr-FR'):'-';const status=String(item.statutPaiement||'-');const badge=status==='PAYE'?\"<span class='label label-success'>PAYE</span>\":\"<span class='label label-default'>\"+status+\"</span>\";return \"<tr><td>\"+d+\"</td><td>\"+Number(item.montant||0)+\" Ar</td><td>\"+badge+\"</td></tr>\";}).join('');",
        "return \"<div class='panel panel-default'><div class='panel-heading'><strong>Factures recentes</strong></div><div class='panel-body'><table class='table table-bordered table-striped'><thead><tr><th>Date</th><th>Montant</th><th>Statut</th></tr></thead><tbody>\"+rows+\"</tbody></table></div></div>\";"
      ]
    },
    "dashboard_chambres_html": {
      "type": "expression",
      "exposed": false,
      "value": [
        "const chambres=Array.isArray($data.chambres)?$data.chambres.slice():[];",
        "if(!chambres.length){return \"<div class='panel panel-default'><div class='panel-heading'><strong>Etat des chambres</strong></div><div class='panel-body'>Aucune chambre disponible.</div></div>\";}",
        "chambres.sort((a,b)=>Number(a.numero||0)-Number(b.numero||0));",
        "const rows=chambres.map(item=>\"<tr><td>\"+(item.numero||'-')+\"</td><td>\"+(item.statut||'-')+\"</td></tr>\").join('');",
        "return \"<div class='panel panel-default'><div class='panel-heading'><strong>Etat des chambres</strong></div><div class='panel-body'><table class='table table-bordered table-striped'><thead><tr><th>Numero</th><th>Statut</th></tr></thead><tbody>\"+rows+\"</tbody></table></div></div>\";"
      ]
    },
    "submit_errors_list": {
      "type": "expression",
      "value": [
        "if($data.formOutput&&$data.formOutput._submitError&&$data.formOutput._submitError.explanations){",
        "const li=$data.formOutput._submitError.explanations.filter(c=>c!==null).map(c=>\"<li>\"+c+\"</li>\").join('');",
        "if(li){return \"<ul>\"+li+\"</ul>\";}}"
      ],
      "exposed": false
    },
    "formOutput": {
      "type": "expression",
      "value": [
        "return {};"
      ],
      "exposed": false
    },
    "taskId": {
      "type": "urlparameter",
      "value": [
        "id"
      ],
      "exposed": false
    }
  },
