    "depart_summary_html": {
      "type": "expression",
      "exposed": false,
      "value": [
        "const c=$data.depart_client||{};",
        "const r=$data.reservation||{};",
        "const ch=$data.depart_chambre||{};",
        "const dateReservation=r.dateReservation?new Date(r.dateReservation).toLocaleDateString('fr-FR'):'-';",
        "const heureDepart=new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});",
        "const rawCat=$data.depart_categorie;",
        "const cat=Array.isArray(rawCat)?((rawCat[0]&&rawCat[0].nom)||'Non definie'):((rawCat&&rawCat.nom)||'Non definie');",
        "const fullName=[c.nomClient,c.prenomClient].filter(v=>v!==undefined&&v!==null&&String(v).trim()!=='').join(' ').trim();",
        "const pageStyle=\"<style>body{background:#eef4f6}.panel{border:0;border-radius:18px;box-shadow:0 14px 34px rgba(12,43,60,.14);overflow:hidden}.panel-heading{background:linear-gradient(135deg,#0f3d57,#1f7a8c)!important;color:#fff!important;border:0}.panel-body{background:linear-gradient(135deg,#ffffff,#f4fbfc)}h2,h3,h4{color:#0f3d57;font-weight:800}.table{background:#fff;border-radius:14px;overflow:hidden}.table>thead>tr>th{background:#0f3d57;color:#fff;border-color:#0f3d57}.alert{border:0;border-radius:16px;box-shadow:0 10px 26px rgba(12,43,60,.10)}.btn-primary{background:#d66b00;border-color:#b85c00;border-radius:14px;font-weight:700}.form-control{border-radius:12px;border-color:#c9dce3}</style>\";",
        "return pageStyle+\"<div class='row'>\"+",
        "\"<div class='col-sm-4'><div class='panel panel-default'><div class='panel-heading'><strong>CLIENT</strong></div><div class='panel-body'><h3>\"+(fullName||'-')+\"</h3><p>Telephone : \"+((c.telephone||'-').toString())+\"</p><p>Piece : \"+((c.pieceIdentite||'-').toString())+\"</p></div></div></div>\"+",
        "\"<div class='col-sm-4'><div class='panel panel-default'><div class='panel-heading'><strong>CHAMBRE</strong></div><div class='panel-body'><h3>\"+(ch.numero!==undefined?ch.numero:'-')+\"</h3><p>Categorie : \"+cat+\"</p></div></div></div>\"+",
        "\"<div class='col-sm-4'><div class='panel panel-default'><div class='panel-heading'><strong>SEJOUR</strong></div><div class='panel-body'><h3>\"+(r.nbNuits!==undefined?r.nbNuits:'-')+\" nuit(s)</h3><p>Date reservation : \"+dateReservation+\"</p><p>Heure depart : \"+heureDepart+\"</p><p>Statut actuel : \"+((ch.statut||'-').toString())+\"</p></div></div></div>\"+",
        "\"</div>\";"
      ]
    },
    "submit_errors_list": {
      "type": "expression",
      "value": [
        "if($data.formOutput&&$data.formOutput._submitError&&$data.formOutput._submitError.explanations){",
        "const li=$data.formOutput._submitError.explanations.filter(c=>c!==null).map(c=>\"<li>\"+c+\"</li>\").join('');",
        "if(li){return \"<ul>\"+li+\"</ul>\";}}"
      ],
      "exposed": false
    },
    "formOutput": {
      "type": "expression",
      "value": [
        "return {};"
      ],
      "exposed": false
    },
    "taskId": {
      "type": "urlparameter",
      "value": [
        "id"
      ],
      "exposed": false
    }
