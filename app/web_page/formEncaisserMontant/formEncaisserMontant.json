      "exposed": false
    },
    "encaisse_summary_html": {
      "type": "expression",
      "exposed": false,
      "value": [
        "const c=$data.encaisse_client||{};",
        "const r=$data.encaisse_reservation||{};",
        "const ch=$data.encaisse_chambre||{};",
        "const rawCat=$data.encaisse_categorie;",
        "const cat=Array.isArray(rawCat)?((rawCat[0]&&rawCat[0].nom)||'Non definie'):((rawCat&&rawCat.nom)||'Non definie');",
        "const fullName=[c.nomClient,c.prenomClient].filter(v=>v!==undefined&&v!==null&&String(v).trim()!=='').join(' ').trim();",
        "return \"<div class='row'>\"+\"<div class='col-sm-6 col-md-3'><div class='panel panel-default'><div class='panel-body'><strong>CLIENT</strong><h4>\"+(fullName||'-')+\"</h4></div></div></div>\"+\"<div class='col-sm-6 col-md-3'><div class='panel panel-default'><div class='panel-body'><strong>CHAMBRE</strong><h4>\"+(ch.numero!==undefined?ch.numero:'-')+\"</h4></div></div></div>\"+\"<div class='col-sm-6 col-md-3'><div class='panel panel-default'><div class='panel-body'><strong>CATEGORIE</strong><h4>\"+cat+\"</h4></div></div></div>\"+\"<div class='col-sm-6 col-md-3'><div class='panel panel-default'><div class='panel-body'><strong>NUITS</strong><h4>\"+(r.nbNuits!==undefined?r.nbNuits:'-')+\"</h4></div></div></div>\"+\"</div>\";"
      ]
    },
    "submit_errors_list": {
      "type": "expression",
      "value": [
        "if($data.formOutput&&$data.formOutput._submitError&&$data.formOutput._submitError.explanations){",
        "const li=$data.formOutput._submitError.explanations.filter(c=>c!==null).map(c=>\"<li>\"+c+\"</li>\").join('');",
        "if(li){return \"<ul>\"+li+\"</ul>\";}}"
      ],
      "exposed": false
    },
    "formOutput": {
      "type": "expression",
      "value": [
        "if($data.facture){return {factureInput:{montant:$data.facture.montant!==undefined?$data.facture.montant:null,statutPaiement:$data.facture.statutPaiement!==undefined?$data.facture.statutPaiement:null}};}"
      ],
      "exposed": false
    },
    "taskId": {
      "type": "urlparameter",
      "value": [
        "id"
      ],
      "exposed": false
    }
