  "variables": {
    "reservation_cliente": {
      "type": "url",
      "value": [
        "{{reservation|lazyRef:'cliente'}}"
      ],
      "exposed": false
    },
    "task": {
      "type": "url",
      "value": [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed": false
    },
    "submit_errors_list": {
      "type": "expression",
      "value": [
        "if($data.formOutput&&$data.formOutput._submitError&&$data.formOutput._submitError.explanations){",
        "const li=$data.formOutput._submitError.explanations.filter(c=>c!==null).map(c=>\"<li>\"+c+\"</li>\").join('');",
        "if(li){return \"<ul>\"+li+\"</ul>\";}}"
      ],
      "exposed": false
    },
    "formOutput": {
      "type": "expression",
      "value": [
        "if(!$data.reservation){$data.reservation={};}",
        "if(!$data.reservation_cliente){$data.reservation_cliente={};}",
        "$data.reservation.cliente=$data.reservation_cliente;",
        "return {reservationInput:{nbNuits:$data.reservation.nbNuits!==undefined?$data.reservation.nbNuits:null,categorieChambre:$data.reservation.categorieChambre!==undefined?$data.reservation.categorieChambre:null,cliente:{nomClient:$data.reservation.cliente.nomClient!==undefined?$data.reservation.cliente.nomClient:null,prenomClient:$data.reservation.cliente.prenomClient!==undefined?$data.reservation.cliente.prenomClient:null,telephone:$data.reservation.cliente.telephone!==undefined?$data.reservation.cliente.telephone:null,email:$data.reservation.cliente.email!==undefined?$data.reservation.cliente.email:null,pieceIdentite:$data.reservation.cliente.pieceIdentite!==undefined?$data.reservation.cliente.pieceIdentite:null}}};"
      ],
      "exposed": false
    },
    "context": {
      "type": "url",
      "value": [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed": false
    },
    "reservation": {
      "type": "url",
      "value": [
        "../{{context.reservation_ref.link}}"
      ],
      "exposed": false
    },
    "taskId": {
      "type": "urlparameter",
      "value": [
        "id"
      ],
      "exposed": false
    }
